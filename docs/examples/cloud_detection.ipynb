    "    f\"Relaxed Cloud-Free Mask\\n({cloud_free_relaxed.sum() / cloud_free_relaxed.size * 100:.1f}% usable)\",\n",
    "    fontsize=14,\n",
    ")\n",
    "axes[1].axis(\"off\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
