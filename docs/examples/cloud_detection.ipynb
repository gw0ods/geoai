    "    print(f\"  CRS: {src_in.crs}\")\n",
    "    print(f\"  Transform: {src_in.transform}\")\n",
    "    print(f\"  Bounds: {src_in.bounds}\")\n",
    "    print(f\"  Bands: {src_in.count}\")\n",
